# Database (Neon Postgres)
DATABASE_URL=postgresql://user:pass@ep-xyz.us-east-2.aws.neon.tech/neondb?sslmode=require

# Auth.js
AUTH_SECRET=your-random-32-char-secret-here

# Ticketmaster Discovery API
TM_API_KEY=your-ticketmaster-api-key

# SeatGeek Platform API
SG_CLIENT_ID=your-seatgeek-client-id
SG_CLIENT_SECRET=your-seatgeek-client-secret

# Cron Security
CRON_SECRET=your-random-cron-secret

# Google Custom Search (optional — for presale code scanning)
# Get API key: https://console.cloud.google.com/apis/credentials
# Create Custom Search Engine: https://cse.google.com/
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
